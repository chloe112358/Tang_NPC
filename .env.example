# Tang Dynasty Dialogue System - Environment Configuration

# Required: Google Gemini API Keys
# One key is used for one NPC branch.
GEMINI_API_KEY_THEATER=your_theater_npc_api_key_here
GEMINI_API_KEY_FOOD=your_food_npc_api_key_here
GEMINI_API_KEY_TBD=your_tbd_npc_api_key_here

# Optional: fallback key used only when a branch-specific key is missing.
# GEMINI_API_KEY=your_fallback_api_key_here

# Optional: LLM Model Configuration
MODEL_NAME=gemini-3.1-flash-lite
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional: local/deployment server port
PORT=8000

# Optional: Input Validation
MAX_INPUT_LENGTH=500

# Optional: Storage Configuration
STORAGE_BACKEND=file
STATE_FILE_PATH=./conversation_state.json

# Optional: Configuration File Paths
PROMPTS_CONFIG_PATH=./config/prompts.json
KNOWLEDGE_CONFIG_PATH=./config/knowledge_windows.json

# Optional: LLM Generation Parameters
TEMPERATURE=0.7
MAX_TOKENS=500
